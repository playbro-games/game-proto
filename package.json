{
	"name": "@playbro-games/game-proto",
	"version": "0.2.1",
	"type": "module",
	"files": [
		"/dist"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	".": {
		"import": "./dist/index.js",
		"types": "./dist/index.d.ts"
	},
	"scripts": {
		"clean": "rm -rf src",
		"proto:gen": "pnpm clean && buf generate",
		"proto:entry": "tsx scripts/gen-entry.ts",
		"docs:build": "redoc-cli build docs/openapi.yaml -o docs/index.html",
		"docs:dev": "redoc-cli serve docs/openapi.yaml",
		"build": "pnpm proto:gen && pnpm proto:entry && vite build",
		"format": "pnpm buf format -w",
		"lint": "pnpm buf lint",
		"test": "echo tests completed",
		"type-check": "echo type check completed"
	},
	"devDependencies": {
		"@bufbuild/buf": "^1.66.0",
		"@bufbuild/protoc-gen-es": "^2.11.0",
		"@types/node": "22.17.1",
		"fast-glob": "^3.3.3",
		"redoc-cli": "^0.13.21",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4"
	},
	"peerDependencies": {
		"@bufbuild/protobuf": "^2.11.0"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"packageManager": "pnpm@10.12.1"
}
